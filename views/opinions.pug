extends layouts/index

block content
    main.container.mt-5 
        h1.text-center.mt-5 #{page} 
        blockquote.text-center Our customers are saying
        include ./layouts/opinions_block
        .row 
            .col-md-12
                h2.d-block.w-100.text-center Give Us a Feedback
                if(errors)
                    each error in errors 
                        .alert.col.alert-danger.text-center= error.message
            .row.justify-content-center.col     
                .col-md-8
                    form(action="/opinions" method="POST") 
                        .form-group
                            label(for="name") Name
                            input#name(type="text",placeholder="First Name",name="name",class="form-control",value=name)
                        .form-group
                            label(for="email") E-Mail
                            input#email(type="text",placeholder="E-Mail",name="email",class="form-control",value=email)
                        .form-group
                            label(for="message") Your Message
                            textarea#message(class="form-control",placeholder="Your message",name="message",rows=3)= message
                        input.btn.btn-block.btn-success(type="submit")