extends layouts/index

block content
    main.container.mt-5 
        .row 
            .col-md-5
                img(src=`/img/destinations_${trip.image}_ln.jpg`, class="img-fluid")
            .col-md-7
                h1 #{trip.title}
                p   
                    svg.icon.icon-tabler.icon-tabler-calendar-time(xmlns='http://www.w3.org/2000/svg' width='36' height='36' viewbox='0 0 24 24' stroke-width='1.5' stroke='#dc135f' fill='none' stroke-linecap='round' stroke-linejoin='round')
                        path(stroke='none' d='M0 0h24v24H0z' fill='none')
                        path(d='M11.795 21h-6.795a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v4')
                        circle(cx='18' cy='18' r='4')
                        path(d='M15 3v4')
                        path(d='M7 3v4')
                        path(d='M3 11h16')
                        path(d='M18 16.496v1.504l1 1')
                    | #{trip.departure_date} - #{trip.return_date}
                p 
                    svg.icon.icon-tabler.icon-tabler-cash(xmlns='http://www.w3.org/2000/svg' width='36' height='36' viewbox='0 0 24 24' stroke-width='1.5' stroke='#cd135f' fill='none' stroke-linecap='round' stroke-linejoin='round')
                        path(stroke='none' d='M0 0h24v24H0z' fill='none')
                        rect(x='7' y='9' width='14' height='10' rx='2')
                        circle(cx='14' cy='14' r='2')
                        path(d='M17 9v-2a2 2 0 0 0 -2 -2h-10a2 2 0 0 0 -2 2v6a2 2 0 0 0 2 2h2')
                    | #{trip.fare} USD
                p 
                    svg.icon.icon-tabler.icon-tabler-users(xmlns='http://www.w3.org/2000/svg' width='36' height='36' viewbox='0 0 24 24' stroke-width='1.5' stroke='#cd135f' fill='none' stroke-linecap='round' stroke-linejoin='round')
                        path(stroke='none' d='M0 0h24v24H0z' fill='none')
                        circle(cx='9' cy='7' r='4')
                        path(d='M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2')
                        path(d='M16 3.13a4 4 0 0 1 0 7.75')
                        path(d='M21 21v-2a4 4 0 0 0 -3 -3.85')
                    | #{trip.availables} Availables
                p= trip.description